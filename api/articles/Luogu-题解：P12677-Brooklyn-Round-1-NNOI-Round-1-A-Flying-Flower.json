h&gt;</span></span></span><br><span class=\"line\"><span class=\"keyword\">using</span> <span class=\"keyword\">namespace</span> std;</span><br><span class=\"line\"><span class=\"type\">const</span> <span class=\"type\">int</span> N=<span class=\"number\">5e5</span><span class=\"number\">+10</span>, MAX=<span class=\"number\">8e6</span><span class=\"number\">+10</span>;</span><br><span class=\"line\"><span class=\"type\">int</span> n, m, q, a[N], b[N], max_a[MAX], max_b[MAX];</span><br><span class=\"line\"><span class=\"type\">bool</span> che[MAX];</span><br><span class=\"line\">vector&lt;<span class=\"type\">int</span>&gt; pri;</span><br><span class=\"line\"></span><br><span class=\"line\"><span class=\"comment\">// 线性筛预处理质数</span></span><br><span class=\"line\"><span class=\"function\"><span class=\"type\">void</span> <span class=\"title\">init</span><span class=\"params\">()</span> </span>{</span><br><span class=\"line\">    <span class=\"keyword\">for</span>(<span class=\"type\">int</span> i=<span class=\"number\">2</span>; i&lt;MAX; i++) {</span><br><span class=\"line\">        <span class=\"keyword\">if</span>(!che[i]) pri.<span class=\"built_in\">push_back</span>(i);</span><br><span class=\"line\">        <span class=\"keyword\">for</span>(<span class=\"type\">int</span> p : pri) {</span><br><span class=\"line\">            <span class=\"keyword\">if</span>(i*p &gt;= MAX) <span class=\"keyword\">break</span>;</span><br><span class=\"line\">            che[i*p] = <span class=\"literal\">true</span>;</span><br><span class=\"line\">            <span class=\"keyword\">if</span>(i%p == <span class=\"number\">0</span>) <span class=\"keyword\">break</span>;</span><br><span class=\"line\">        }</span><br><span class=\"line\">    }</span><br><span class=\"line\">}</span><br><span class=\"line\"></span><br><span class=\"line\"><span class=\"function\"><span class=\"type\">int</span> <span class=\"title\">main</span><span class=\"params\">()</span> </span>{</span><b